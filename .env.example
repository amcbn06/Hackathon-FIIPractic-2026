# Copy this file to .env and fill in real values. Never commit .env.

# ----- Required ------------------------------------------------------------

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_random_64_char_hex_string

# Comma-separated emails granted admin powers (approve/reject/delete places).
# Whoever logs in with one of these is an admin. No DB migration needed.
ADMIN_EMAILS=demo@onepick.app

# ----- AI (optional, off by default to save tokens) ------------------------

# Set to "true" to enable Claude-generated "why this pick" reasons.
# Off by default — picks fall back to the place's curator description or a template.
USE_ANTHROPIC=false

# Only needed if USE_ANTHROPIC=true. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ----- Place promotion threshold -------------------------------------------

# How many community upvotes a 'pending' place needs to auto-promote to 'approved'.
PLACE_PROMOTION_VOTES=3

# ----- Frontend ------------------------------------------------------------

# Where the Streamlit frontend should send API calls
BACKEND_URL=http://localhost:8000

# Set to "true" to make the frontend use hardcoded mock data (no backend needed)
MOCK_MODE=false

# ----- Legacy --------------------------------------------------------------

# Geoapify was the previous POI source. The current build uses a crowdsourced DB
# instead and ignores this key. Kept here in case the team wants to bring it
# back (e.g. as a one-shot script to bootstrap seed_places.json for a new city).
GEOAPIFY_API_KEY=
