# Copy this file to .env and fill in real values. Never commit .env.

# Geoapify free tier — sign up at https://myprojects.geoapify.com
GEOAPIFY_API_KEY=your_geoapify_key_here

# Anthropic API key for AI-generated "why this pick" reasons
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_random_64_char_hex_string

# Where the Streamlit frontend should send API calls
BACKEND_URL=http://localhost:8000

# Set to "true" to make the frontend use hardcoded mock data (no backend needed)
MOCK_MODE=false
